NODE_ENV=development
PORT=3001
API_PREFIX=api
# Comma-separated allowed frontend origins. Use deployed frontend origin(s) in production.
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=false
# MongoDB Atlas URI (must start with mongodb:// or mongodb+srv://)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/
MONGODB_DB=iceberg
# Required for password reset e-mails
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@example.com
RESEND_FROM_NAME=Iceberg
