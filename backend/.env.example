NODE_ENV=development
PORT=3001
API_PREFIX=api
# Comma-separated allowed frontend origins. Use deployed frontend origin(s) in production.
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=false
# Set false when users should only be created by an authenticated admin.
PUBLIC_REGISTRATION_ENABLED=true
# MongoDB Atlas URI (must start with mongodb:// or mongodb+srv://)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/
MONGODB_DB=iceberg
# Optional startup seed for the platform owner account.
# Set both email and password to create/activate a super admin on backend startup.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_ORGANIZATION_NAME=Iceberg Admin
SUPER_ADMIN_ORGANIZATION_SLUG=iceberg-admin
# Required for password reset e-mails
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@example.com
RESEND_FROM_NAME=Iceberg
