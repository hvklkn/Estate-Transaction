{
  "name": "real-estate-transaction-platform",
  "description": "Full-stack real estate transaction management platform.",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "install:backend": "npm --prefix backend install",
    "install:frontend": "npm --prefix frontend install",
    "dev:backend": "npm --prefix backend run start:dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "typecheck:frontend": "npm --prefix frontend run typecheck",
    "test:backend": "npm --prefix backend run test",
    "test:e2e:backend": "npm --prefix backend run test:e2e"
  },
  "dependencies": {
    "mongodb": "^7.1.1"
  }
}
