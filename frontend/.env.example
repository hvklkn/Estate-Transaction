# Required in production. Must include backend API prefix.
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NUXT_PUBLIC_APP_ENV=development
# Mirror backend PUBLIC_REGISTRATION_ENABLED so the register tab can be hidden.
NUXT_PUBLIC_REGISTRATION_ENABLED=true
# Optional when building for Vercel manually (npm run build:vercel uses this automatically).
# NITRO_PRESET=vercel
